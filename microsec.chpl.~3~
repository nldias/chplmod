use nstrings only ifind;
// -----------------------------------------------------------------------------
// --> convert microseconds to an int!
// -----------------------------------------------------------------------------
inline proc microsec(stime: string): int {
   var idec = (stime.ifind(".")+1);
   if idec < 0 then {
      return 0;
   }
   var smicro = stime[idec..];
   var l0 = smicro.size;
   var lmiss = 6 - l0;
   var sret = smicro + lmiss*"0";
   return sret: int;
}
