\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}



\subsection{Theory}

Calculates
\begin{equation}
\Trv\{x,y,z\} = \frac{1}{n}\sum_{i=1}^n (x_i - \overline{x})(y_i -
