\section{\texttt{reglin}: linear regression}

\subsection{Use}
\iexec[quiet,trace,stdout=xtract.txt]{grep 'proc reglin(' -A4 nstat.chpl}

\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}



\subsection{Theory}


Given a pair of data $\vet{x}=(x_1,\ldots,x_{n})$,
$\vet{y}=(y_1,\ldots,y_{n})$, calculates the linear regression
\[
\widehat{y} = ax + b,
\]
where
\begin{align}
  a &= \frac{\Cov\{x,y\}}{\Var\{x\}}, \label{eq:a-est}\\
  b &= \overline{y} - a\overline{x},\label{eq:b-est}
\end{align}
and
\begin{equation}
r = \frac{\Cov\{x,y\}}{\sqrt{\Var\{x\}\Var\{y\}}}\label{eq:r-est}
\end{equation}
is the correlation coefficient.

\section{\texttt{reglina:} linear regression through the origin}

\subsection{Use}
\iexec[quiet,trace,stdout=xtract.txt]{grep 'proc reglina(' -A8 nstat.chpl}

\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}


\subsection{Theory}

Let
\begin{equation}
  Y = ax + E,
\end{equation}
where $Y$ is a random variable, $E$ is a random variable independent of $x$, and $x$ is not
random. 

Form the objective function
\begin{equation}
   F_O(a) = \frac{1}{n} \sum_{i=1}^n ( y_i - ax_i)^2.
\end{equation}
Differentiating with respect to $a$ gives the least-squares estimate of $a$:
\begin{align}
\sum_{i=1}^n 2(y_i - ax_i)(-x_i)            & = 0, \nonumber                                                                    \\
-\sum_{i=1}^n x_i y_i + a\sum_{i=1}^n x_i^2 & = 0,\nonumber                                                                     \\
a = \frac{\sum_{i=1}^n x_i y_i}{\sum_{i=1}^n x_i^2}.
\end{align}
The ``error'' involved in estimating $a$ can be found by re-interpreting $a$ (and $y_i$) as
random variables, and assuming that the $Y_i$'s are independent:
\begin{align}
A                                           & = \frac{\sum_{i=1}^n x_i Y_i}{\sum_{i=1}^n x_i^2},\nonumber                       \\
\Var\{A\}                                   & = \frac{\sum_{i=1}^n x_i^2 \Var\{Y\}}{\left[\sum_{i=1}^n x_i^2\right]^2}.
\end{align}
Replacing the expectations with sample moments:
\begin{align}
\Var\{a\}                                   & = \frac{\sum_{i=1}^n x_i^2}{\left[\sum_{i=1}^n x_i^2\right]^2}\Var\{y\},\nonumber \\
                                            & = \frac{\Var\{y\}}{\sum_{i=1}^n x_i^2};                                           \\
s_a                                         & = \sqrt{\frac{\Var\{y\}}{\sum_{i=1}^n x_i^2}}.
\end{align}
The standard error of estimate shouldn't be too difficult to find, now:
\begin{align}
s_e^2                                       & = \frac{1}{n} \sum_{i=1}^n \left[ y_i - ax_i\right]^2\nonumber                    \\
                                            & = \frac{1}{n}\sum_{i=1}^n \left[ y_i^2 - 2 a x_i y_i + a^2 x_i^2\right]\nonumber  \\
                                            & = \frac{1}{n} \left[ \sum_{i=1}^n y_i^2 - 2a \sum_{i=1}^n x_i y_i + a^2 \sum_{i=1}^n x_i^2\right].
\end{align}
Finally, by definition the coefficient of determination is
\begin{equation}
c_d = 1 - \frac{s_e^2}{\Var\{y\}}.
\end{equation}

\section{\texttt{reglinpar:} linear regression, with error estimates}

\subsection{Use}
\iexec[quiet,trace,stdout=xtract.txt]{grep 'proc reglinpar(' -A10 nstat.chpl}

\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}


\subsection{Theory}

We follow \citet[Chapter 4]{benjamim.cornell:probability}

The general probabilistic model is
\begin{equation}
  Y = ax + b + E,
\end{equation}
where $Y$ is a random variable, $E$ is a random variable independent of $x$, and $x$ is not
random. 

The estimates of $a$ and $b$ and the correlation coefficient $r$
are already given in (\ref{eq:a-est}), (\ref{eq:b-est}) and
(\ref{eq:r-est}). The standard error of estimate is given by
Eq. (4.3.27) of \cite{benjamim.cornell:probability}:
\begin{equation}
s_e^2 = \frac{n}{n-2}\left(1 - r^2\right)\Var\{y\}.\label{eq:se-est}
\end{equation}
The variances of $a$ and $b$ (actually assumed to be random variables
$A$ and $B$ and then estimated by the sample statistics) are
\begin{align}
  s_a^2 &= \frac{s_e^2}{n\Var\{x\}}, \\
  s_b^2 &= \frac{s_e^2}{n}\left(1 + \frac{\overline{x}^2}{\Var\{x\}} \right).
\end{align}

\section{\texttt{ols}: Ordinary least squares}

\subsection{Use}
\iexec[quiet,trace,stdout=xtract.txt]{grep 'proc ols' -A11 nstat.chpl}

\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}

\subsection{Theory}

Calculates the multiple linear regression coefficients $\vet{c}$ of
\begin{equation}
\met{\widehat{y}\,}_{n\times 1} = \met{x}_{n\times m}\met{c}_{m\times 1},
\end{equation}
where the $x$ data are
\begin{equation}
  \met{x} = \begin{bmatrix}
    1 & x_{11} & x_{12} & \ldots & x_{1(m-1)} \\
    1 & x_{21} & x_{22} & \ldots & x_{2(m-1)} \\
      &        &        & \vdots \\
    1 & x_{n1} & x_{n2} & \ldots & x_{1(m-1)} \\
  \end{bmatrix}.
\end{equation}
For details, see for example Chapter 7 of
\cite{netter1983applied-linear-regression-models}. Start with the
corresponding equation with $y$ data,
\begin{equation}
\met{y}_{n\times 1} = \met{x}_{n\times m}\met{c}_{m\times 1},
\end{equation}
which cannot be solved for $\met{c}$, and do:
\begin{align}
     \met{x}^\tr_{m\times n}\met{y}_{n\times 1} &=
     \underbrace{\met{x}^\tr_{m\times n}\met{x}_{n\times
         m}}_{\met{A}_{m\times m}}\met{c}_{m\times 1} \nonumber \\
     &= \met{A}_{m\times m}\met{c}_{m\times 1}   \Rightarrow \nonumber
     \\
     \met{c}_{m\times 1} &= \met{A}^{-1}_{m\times
       m}\met{x}^\tr_{m\times n}\met{y}_{n\times 1}\blob
\end{align}
The standard error of estimate is
\begin{equation}
s_e^2 = \frac{1}{n-m}\met{\met{y}-\met{\,\widehat{y}\,}}^\tr\met{\met{y}-\met{\,\widehat{y}\,}};
\end{equation}
the covariance matrix of $\vet{c}$ is
\begin{equation}
\met{\Cov\{\vet{c}\}} = s_e^2\,\met{A}^{-1},
\end{equation}
and the adjusted coefficient of multiple determination
\cite[][Eq. (7.33)]{netter1983applied-linear-regression-models} is
\begin{equation}
C_D = 1 - \frac{n-1}{n}\frac{s_e^2}{\Var\{y\}}.
\end{equation}


