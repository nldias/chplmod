\section{\texttt{quartiles}: returns the quartiles of an array}

\subsection{Use}
\iexec[quiet,trace,stdout=xtract.txt]{grep 'proc quartiles' -A3 nstat.chpl}

\lstinputlisting[style=lstchapelf, numbers=none]{xtract.txt}



\subsection{Theory}


Makes a copy of the array; sorts it; the cumulative distribution
function over the sorted array $(x_0, x_1, \ldots, x_{n-1})$ is
\begin{equation}
F(x_i) = \frac{i}{n-1}.
\end{equation}
Then interpolates
\begin{equation}
q_j = F^{-1}\left( j\times 0.25\right), \qquad j = 1,2,3,
\end{equation}
and returns $(q_1, q_2, q_3)$.

