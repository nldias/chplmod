// -----------------------------------------------------------------------------
// --> todec: converts degrees, minutes and seconds to decimals
//
// input:  ggg.mmss  degrees (gg), minutes (mm), seconds (ss) 
// output: ggg.xxxx  decimal degrees
// -----------------------------------------------------------------------------


proc todec(
   in xmsc: real
   ): real {
   var xint = trunc(xmsc);
   var xdec = xint;
   xmsc = (xmsc - xint)*100.0;
   xint = nearbyint(xmsc);
   xdec += xint/60.0;
   xmsc = (xmsc - xint)*100;
   xdec += xmsc/3600.0;
   return(xdec) ;
}
// -----------------------------------------------------------------------------
// --> rad2dec: convert from radians to decimal degrees
// -----------------------------------------------------------------------------
inline proc rad2dec(const in r: real(?w)): real(w) {
   return r*180.0/pi;
}
// -----------------------------------------------------------------------------
// --> dec2rad: convert from decimal degrees to radians
// -----------------------------------------------------------------------------
inline proc dec2rad(const in r: real(?w)): real(w) {
   return r*pi/180.0;
}
