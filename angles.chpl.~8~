use Math only nearbyint, pi;
use IO only stderr;
// -----------------------------------------------------------------------------
// --> todmsc: converts decimal degrees to degrees, minutes, seconds and
//     hundredths of seconds
//
// input:  ddd.xxxxxx -- decimal degrees
// output: ddd.mmsscc -- degrees (ddd), minutes (mm), seconds (ss) & hundredths
//                       (cc)
// -----------------------------------------------------------------------------
proc todms(
   const in decimalDegrees: real
   ): real {
// -----------------------------------------------------------------------------   
// 1. Degrees are the integer part of the decimal degrees
// -----------------------------------------------------------------------------   
   var degrees = trunc(decimalDegrees);
// -----------------------------------------------------------------------------   
// 2. Take the absolute fractional part and multiply by 60 for minutes
// -----------------------------------------------------------------------------   
   var fractionalPart = abs(decimalDegrees - degrees);
   var minutesFull = fractionalPart * 60.0;
   var minutes = trunc(minutesFull);
// -----------------------------------------------------------------------------   
// 3. Take the remaining fractional part of minutes and multiply by 60 for seconds
// -----------------------------------------------------------------------------   
   var  seconds = (minutesFull - minutes) * 60.0;
   if isClose(seconds,60.0,absTol=0.00001) then {
      minutes += 1;
      seconds = 0.0;
   }
   if isClose(minutes,60.0,absTol=0.00001) then {
      degrees += 1;
      minutes = 0.0;
   }
   return degrees + minutes/100.0 + seconds/10000.0 ;
}



