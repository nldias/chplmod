proc togmsc(
   in xdec: real
   ): real {
   var xint: real;
   var xmsc, part: real;
   xint = trunc(xdec); // modf(xdec,&xint) ;
   xmsc = xint ;
   stderr.writeln("xmsc = ",xmsc);
   xdec = ( xdec - xint ) * 60.0 ;
   xint = trunc(xdec); //   modf(xdec,&xint) ;
   part = xint/100.0;
   writeln("part = ",part);
   if part == 0.60 then {
      part = 1.0;
   }
   xmsc = xmsc + part; // xint / 100.0 ;
   stderr.writeln("xmsc = ",xmsc);
   xdec = (xdec - xint) * 60.0 ;
   xint = trunc(xdec);
   part = xdec/10000;
   writeln("part = ",part);
   if part == 0.0060 then {
      part = 0.01;
   }
   xmsc = xmsc + part;
   stderr.writeln("xdec = ",xdec);
   stderr.writeln("xint = ",xint);
   stderr.writeln("xmsc = ",xmsc);
   return(xmsc)  ;
}

// -----------------------------------------------------------------------------
// --> todec: converts degrees, minutes and seconds to decimals
//
// input:  ggg.mmss  degrees (gg), minutes (mm), seconds (ss) 
// output: ggg.xxxx  decimal degrees
// -----------------------------------------------------------------------------


proc todec(
   in xmsc: real
   ): real {
   var xint = trunc(xmsc);
   var xdec = xint;
   xmsc = (xmsc - xint)*100.0;
   xint = nearbyint(xmsc);
   xdec += xint/60.0;
   xmsc = (xmsc - xint)*100;
   xdec += xmsc/3600.0;
   return(xdec) ;
}
// -----------------------------------------------------------------------------
// --> rad2dec: convert from radians to decimal degrees
// -----------------------------------------------------------------------------
inline proc rad2dec(const in r: real(?w)): real(w) {
   return r*180.0/pi;
}
// -----------------------------------------------------------------------------
// --> dec2rad: convert from decimal degrees to radians
// -----------------------------------------------------------------------------
inline proc dec2rad(const in r: real(?w)): real(w) {
   return r*pi/180.0;
}
