use nstrings only ifind;
// -----------------------------------------------------------------------------
// --> convert microseconds to an int! stime can be any string containing a
// decimal separator "."; the microseconds will be counted as the string after
// the ".". If "." is not present, returns 0.
// -----------------------------------------------------------------------------
inline proc microsec(stime: string): int {
   var zdec = stime.ifind(".");
   if zdec < 0 then {
      return 0;
   }
   var idec = zdec + 1;
   var smicro = stime[idec..];
   var l0 = smicro.size;
   var lmiss = 6 - l0;
   var sret = smicro + lmiss*"0";
   return sret: int;
}
