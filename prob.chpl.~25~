use Math only exp, lnGamma, log;
use Random only fillRandom, randomStream;
use dgrow;
// -----------------------------------------------------------------------------
// 2026-06-23T13:49:44 Including seeds in the procs to generate a Poisson random
// variable
// -----------------------------------------------------------------------------
proc Normal(const in P: real): real {
// -----------------------------------------------------------------------------
// --> Normal: inverse of N(0,1) CDF
//    
// MICHAEL J. WICHURA ALGORITHM AS241 APPL. STATIST. (1988) VOL. 37(3) 477-484
//
// PRODUCES THE NORMALDEVIATE Z CORRESPONDING TO A GIVEN LOWER TAIL AREA OF P; Z
// IS ACCURATE TO ABOUT 1 PART IN 10**16.
//
// THE HASH SUMS BELOW ARE THE SUMS OF THE MANTISSAS OF THE COEFFICIENTS. THEY
// ARE INCLUDED FOR USE IN CHECKING TRANSCRIPTION.
// -----------------------------------------------------------------------------
param
   ZERO = 0.0E0,
   ONE = 1.0E0,
   HALF = ONE/2.0E0, 
   SPLIT1 = 0.425E0,
   SPLIT2 = 5.0E0,
   CONST1 = 0.180625E0,
   CONST2 = 1.6E0;
// -----------------------------------------------------------------------------
// COEFFICIENTS FOR P CLOSE TO 1/2
// -----------------------------------------------------------------------------
param
   A0 = 3.38713_28727_96366_6080E0, 
   Al = 1.33141_66789_17843_7745E2,
   A2 = 1.97159_09503_06551_4427E3,
   A3 = 1.37316_93765_50946_1125E4, 
   A4 = 4.59219_53931_54987_1457E4, 
   A5 = 6.72657_70927_00870_0853E4, 
   A6 = 3.34305_75583_58812_8105E4, 
   A7 = 2.50908_09287_30122_6727E3, 
   B1 = 4.23133_30701_60091_1252E1, 
   B2 = 6.87187_00749_20579_0830E2, 
   B3 = 5.39419_60214_24751_1077E3, 
   B4 = 2.12137_94301_58659_5867E4, 
   B5 = 3.93078_95800_09271_0610E4, 
   B6 = 2.87290_85735_72194_2674E4, 
   B7 = 5.22649_52788_52854_5610E3;
// -----------------------------------------------------------------------------
// HASH SUM AB    55.88319 28806 14901 4439 
// -----------------------------------------------------------------------------
// -----------------------------------------------------------------------------
// COEFFICIENTS FOR P NEITHER CLOSE TO 1/2 NOR 0 OR 1
// -----------------------------------------------------------------------------
param
   C0 = 1.42343_71107_49683_57734E0,
   Cl = 4.63033_78461_56545_29590E0, 
   C2 = 5.76949_72214_60691_40550E0,
   C3 = 3.64784_83247_63204_60504E0,
   C4 = 1.27045_82524_52368_38258E0, 
   C5 = 2.41780_72517_74506_11770E-1, 
   C6 = 2.27238_44989_26918_45833E-2, 
   C7 = 7.74545_01427_83414_07640E-4, 
   D1 = 2.05319_16266_37758_82187E0, 
   D2 = 1.67638_48301_83803_84940E0, 
   D3 = 6.89767_33498_51000_04550E-1, 
   D4 = 1.48103_97642_74800_74590E-1, 
   D5 = 1.51986_66563_61645_71966E-2, 
   D6 = 5.47593_80849_95344_94600E-4, 
   D7 = 1.05075_00716_44416_84324E-9;
// -----------------------------------------------------------------------------
// HASH SUM CD        49.33206 50330 16102 89036 
// -----------------------------------------------------------------------------
// -----------------------------------------------------------------------------
// COEFFICIENTS FOR P NEAR 0 OR 1 
// -----------------------------------------------------------------------------
param
   E0 = 6.65790_46435_01103_77720E0,
   El = 5.46378_49111_64114_36990E0,
   E2 = 1.78482_65399_17291_33580E0,
   E3 = 2.96560_57182_85048_91230E-1, 
   E4 = 2.65321_89526_57612_30930E-2, 
   E5 = 1.24266_09473_88078_43860E-3, 
   E6 = 2.71155_55687_43487_57815E-5, 
   E7 = 2.01033_43992_92288_13265E-7, 
   Fl = 5.99832_20655_58879_37690E-1, 
   F2 = 1.36929_88092_27358_05310E-1,
   F3 = 1.48753_61290_85061_48525E-2,
   F4 = 7.86869_13114_56132_59100E-4, 
   F5 = 1.84631_83175_10054_68180E-5, 
   F6 = 1.42151_17583_16445_88870E-7, 
   F7 = 2.04426_31033_89939_78564E-15;
// -----------------------------------------------------------------------------
// HASH SUM EF  47.52583 31754 92896 71629 
// -----------------------------------------------------------------------------
   var Q,R,res: real;
   Q = P - HALF;
   if (abs(Q) <= SPLIT1) then {
      R = CONST1 - Q * Q;
      res = Q *
      (((((((A7*R + A6)*R + A5)*R + A4)*R + A3)*R + A2)*R + Al)*R + A0) /
      (((((((B7*R + B6)*R + B5)*R + B4)*R + B3)*R + B2)*R + B1)*R + ONE);
      return res;
   }
   else if (Q <= 0.0) then {
      R = P;
   }
   else {
      R = ONE - P;
   }
   if ( R <= 0.0) then {
      halt("prob-->ppnd: P < 0.0 or P > 1.0");
   }
   R = sqrt(-log(R));
   if ( R <= SPLIT2) then {
      R = R - CONST2;
      res = (((((((C7*R + C6)*R + C5)*R + C4)*R + C3)*R + C2)*R + Cl)*R + C0) /
            (((((((D7*R + D6)*R + D5)*R + D4)*R + D3)*R + D2)*R + D1)*R + ONE);
   }
   else { 
      R = R - SPLIT2;
      res = (((((((E7*R + E6)*R + E5)*R + E4)*R + E3)*R + E2)*R + El)*R + E0) /
            (((((((F7*R + F6)*R + F5)*R + F4)*R + F3)*R + F2)*R + Fl)*R + ONE);
   }
   if ( Q <= 0.0) then {
      res = -res;
   }
   return res;
}
// -----------------------------------------------------------------------------
// --> fillNormal: fills array x with N(0,1) random variables
// -----------------------------------------------------------------------------
proc fillNormal(
   ref x: [] real,
   const in isee: int = 0)
   where x.rank == 1 {
   const n = x.size;
   var u: [1..n] real;
   fillRandom(u,isee);
   forall (anx, anu) in zip(x,u) do {
      anx = Normal(anu);
   }
}

