// -----------------------------------------------------------------------------
// In order to use Chapel's Random module, we need to create and start a
// randomStream.
// -----------------------------------------------------------------------------


// -----------------------------------------------------------------------------
// --> Poisson: generates a random variable with Poisson distribution, parameter
// lam. 
// -----------------------------------------------------------------------------
proc Poisson(
   const in lam: real,
   const in isee: int = 0
   ): int {
   if (lam >= 10.0) {
      // For large lambda, use Hörmann's Transformed Rejection Method
      return Poisson_ptrs(lam,isee);
   } else if (lam == 0.0) {
      return 0;
   } else {
      // For small lambda, use the sequential multiplication method
      return Poisson_mult(lam),isee;
   }
}

// -----------------------------------------------------------------------------
// --> Poisson_mult: for 0 < lam < 10.0.
// -----------------------------------------------------------------------------
proc Poisson_mult(
   const in lam: real,
   const in isee: int = 0
   ): int {
   const enlam = exp(-lam);
   var X: int ;
   var prod, U: real;
   var UPoissonStream = new randomStream(real,isee);
   X = 0;
   prod = 1.0;
   while (true) {
      U = UPoissonStream.next(); // Generates a uniform random float in [0, 1)
      prod *= U;
      if (prod <= enlam) {
         return X;
      }
      X += 1; // X++;
   }
   return -1;       // this should never happen
}

// -----------------------------------------------------------------------------
// --> Poisson_ptrs: for lam >= 10.0.
// -----------------------------------------------------------------------------
proc Poisson_ptrs(
   const in lam: real,
   const in isee: int = 0
   ): int {
   const slam = sqrt(lam);
   const loglam = log(lam);
   const b = 0.931 + 2.53 * slam;
   const a = -0.059 + 0.02483 * b;
   const invalpha = 1.1239 + 1.1328 / (b - 3.4);
   const vr = 0.9277 - 0.62241 / slam;
   var k: int;
   var UPoissonStream = new randomStream(real,isee);
   while (true) {
      var U = UPoissonStream.next() - 0.5;
      var V = UPoissonStream.next(); 
      var u = 0.5 - abs(U);
      if ((U < 0.0) && (u < 0.0)) then {
         continue;
      }
      var us = 0.5 - U * U / u;
      k = floor((2.0 * a / u + b) * U + lam + 0.43): int;
      // Immediate acceptance via the "squeeze" boundary conditions
      if ((us >= 0.0) && (V <= vr)) {
         return k;
      }
      if ((k < 0) || ((us < 0.0) && (V >= us))) then {
         continue;
      }
      // Mathematical acceptance step (safeguard log evaluation)
      if (log(V * invalpha / (a / (u * u) + b)) <= k * loglam - lam - lnGamma(k+1)) {
         return k;
      }
   }
   return -1;       // this should never happen
}

// -----------------------------------------------------------------------------
// --> fillPoisson:  fills array x with Poisson(lam) random variables
// -----------------------------------------------------------------------------
proc fillPoisson(
   const in lam: real,
   ref x: [] int
   ) where x.rank == 1 {
   const n = x.size;
   forall anx in x  do {
      anx = Poisson(lam);
   }
}
// -----------------------------------------------------------------------------
// --> lognormalPar: estimate sigma, theta and a from method of moments with
// sample mean mx, sample var varx, sample skewness gx. Notation from
//
// Crooks, G. E. Field Guide to Continuous Probability Distributions
// self-published, 2017, url = {http://threeplusone.com/fieldguide}.
//
// 2026-06-16T11:15:53 fixing an error in the calculation of eta. Now
// it should be correct.
// -----------------------------------------------------------------------------
proc lognormalPar(
   const in mx: real,
   const in varx: real,
   const in gx: real
   ): (real,real,real) {
   // const me = exp(1.0);
   var eta: real; //  = me;
   // var gx  = (eta+2.0)*sqrt(eta-1.0);
   // writeln("gx = ",gx);
   const h = 4 + gx**2;
   const Delta = (sqrt(h*(h-4.0)) + h - 2.0);
   // writeln("Delta = ",Delta);
   var num = Delta**(2.0/3.0) - 2.0**(1.0/3.0)*Delta**(1.0/3.0) + 2.0**(2.0/3.0);
   // writeln("num = ",num);
   var den = 2.0**(1.0/3.0) * Delta**(1.0/3.0);
   // writeln("den = ",den);
   eta = num/den;
   var hatg: real;
   if isClose(eta-1,0.0,absTol=1.0e-10) then {
      hatg = 0.0;
   }
   else {
      hatg = (eta+2.0)*sqrt(eta-1.0);
   }
   // writeln("eta = ",eta," gx = ",gx," hat{g} = ",hatg);
   const sigma = sqrt(log(eta));
   // writeln("sigma = ",sigma);
   const theta = sqrt( varx/((eta-1)*eta)) ;
   const a = mx - theta*sqrt(eta) ;
   return (sigma,theta,a);
}

// -----------------------------------------------------------------------------
// --> NeymanScott: generates a simple Neyman-Scott process in a
// square (2L)×(2L). The lower left corner of the region is (-L,-L)
// and the upper right corner is (+L,+L).
// -----------------------------------------------------------------------------
proc NeymanScott(
   const in L: real,          // 1/2 size of the square (from -L to +L)
   const in kappa: real,      // parent intensity
   const in nu: real,         // mean number of offspring per parent
   const in delpx: real,      // cluster spread
   out npts: int,             // total number of points generated
   const in isee: int = 0     // all seeds are in here
   )
   : ([1..npts] real, [1..npts] real)   // (x,y) of generated points
{
   const area = 4.0*L**2;        // area of the square
   // --------------------------------------------------------------------------
   // A random stream for seeds: note taht a randomStream does not output its
   // state, which is used for seeding only. In this proc, I re-seed with rstr
   // and I am fairly confident that the resulting random numbers will be
   // "independent".
   // --------------------------------------------------------------------------
   var rstr = new randomStream(int,isee);
   // --------------------------------------------------------------------------
   // Simulate Parents (Poisson process)
   // --------------------------------------------------------------------------
   var n_parents = Poisson(kappa * area,rstr.next());
   var
      parent_x,               // abscissa of each parent cluster
      parent_y:               // ordinate of each parent cluster
      [1..n_parents] real;
   // --------------------------------------------------------------------------
   // Sample between 0 and 1
   // --------------------------------------------------------------------------
   fillRandom(parent_x,rstr.next());
   fillRandom(parent_y,rstr.next());
   // --------------------------------------------------------------------------
   // Rescale between -L and +L
   // --------------------------------------------------------------------------
   parent_x = 2*L*parent_x - L;
   parent_y = 2*L*parent_y - L;
   // --------------------------------------------------------------------------
   // Simulate offspring.
   // --------------------------------------------------------------------------
   var Dout = {1..10};
   var xout, yout: [Dout] real ;
   npts = 0;
   for k in 1..n_parents do {
      var n_daughters = Poisson(nu,rstr.next());  //  draw number of offspring
      // -----------------------------------------------------------------------
      // If there are no daughters, continue.
      // -----------------------------------------------------------------------
      if n_daughters == 0 then continue;
      // -----------------------------------------------------------------------
      // Displace around parent (Gaussian distribution)
      // -----------------------------------------------------------------------
      var
         dx,
         dy
         : [1..n_daughters] real;
      // -----------------------------------------------------------------------
      // Draw displacements (dx,dy) ~ N(0,delpx) from parents.
      // -----------------------------------------------------------------------
      fillNormal(dx,rstr.next()); 
      fillNormal(dy,rstr.next()); 
      dx *= delpx;
      dy *= delpx;
      // -----------------------------------------------------------------------
      // Displace daughters.
      // -----------------------------------------------------------------------
      var daughter_x = parent_x[k] + dx;
      var daughter_y = parent_y[k] + dy;
      // -----------------------------------------------------------------------
      // Add kids in this cluster to all sampled points.
      // -----------------------------------------------------------------------
      for l in 1..n_daughters do {
         var xx = daughter_x[l];
         var yy = daughter_y[l];
         // if (xx < -L || xx >= L || yy < -L || yy >= L ) then continue;
         npts += 1;
         dgrow(npts,Dout);
         xout[npts] = xx;
         yout[npts] = yy;
      }
   }
   Dout = {1..npts};
   return (xout,yout);
}

