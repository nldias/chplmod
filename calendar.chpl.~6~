// -----------------------------------------------------------------------------
const NNdays:
[false..true,1..12] int = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31;
                    31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31] ;
proc Leap(
   const in Year: int
   ): bool {
   return ( ( (Year % 4 == 0) && (Year % 100 != 0) ) || (Year % 400 == 0) ) ;
}
// -----------------------------------------------------------------------------
// --> JtoMD: From Julian [1--366] to (Month,Day)
// -----------------------------------------------------------------------------
proc JtoMD(
   const in bis: bool,        // leap year?
   in jday: int               // julian day, 1--366
   ): (int,int) { 
   var Month = 1;
   while ( jday > NNdays[bis,Month] ) do {
      jday -= NNdays[bis,Month] ;
      Month += 1 ;
   }
   return (Month,jday);
}
// -----------------------------------------------------------------------------
// --> MDtoJ: From (Month,Day) to Julian 
// -----------------------------------------------------------------------------
proc MDtoJ(
   const in bis: bool,        // leap year?
   const in Month: int,       // Month
   in Day: int                // initially, Day of Month
   ): int { 
   var i = 1 ;
   while  ( i < Month) do { 
      Day += NNdays[bis,i]  ;
      i += 1;
   }
   return Day;
}

// -----------------------------------------------------------------------------
// --> YMDHtoStr: convert YMDH to string
// -----------------------------------------------------------------------------
inline proc YMDHtoStr(
   const in year: int,
   const in month: int,
   const in day: int,
   const in hour: int
   ): string {
   var s = "%4i-%02i-%02i:%02i".format(year,month,day,hour);
   return s;
}
// -----------------------------------------------------------------------------
// --> YMDtoStr: convert YMDH to string
// -----------------------------------------------------------------------------
inline proc YMDtoStr(
   const in year: int,
   const in month: int,
   const in day: int
   ): string {
   var s = "%4i-%02i-%02i".format(year,month,day);
   return s;
}

