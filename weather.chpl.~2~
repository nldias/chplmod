param TwoPi = 2*pi;
use nmth only hypot;
// -----------------------------------------------------------------------------
// --> WindDir: get wind direction from (u,v) (zonal, meridional) wind.
// -----------------------------------------------------------------------------
inline proc WindDir(
   const in u: real,          // zonal wind
   const in v: real           // meridional wind
   ): real {
   var theta = atan2(v,u);
   return mod(theta-halfPi,Twoi);
}
// -----------------------------------------------------------------------------
// --> WindSpped: get wind speed from (u,v) (zonal, meridional) wind.
// -----------------------------------------------------------------------------
inline proc WindSpeed(
   const in u: real,          // zonal wind
   const in v: real           // meridional wind
   ): real {
   return hypot(u,v);
}
   

